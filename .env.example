SPRING_PROFILES_ACTIVE=fixture,http

PRODOPS_BIND_ADDRESS=127.0.0.1
PORT=8080
MANAGEMENT_PORT=8081
PRODOPS_PUBLIC_BASE_URL=http://127.0.0.1:8080

PRODOPS_JWT_ENABLED=false
PRODOPS_JWT_ISSUER_URI=
PRODOPS_JWT_JWKS_URI=
PRODOPS_JWT_AUDIENCE=prodops-control-tower-mcp
PRODOPS_REQUIRED_SCOPE=prodops.read

KUBECONFIG=
KUBE_CONTEXT=
PROMETHEUS_BASE_URL=https://prometheus.uat.example.internal
PROMETHEUS_BEARER_TOKEN=
GRAFANA_BASE_URL=https://grafana.uat.example.internal
GRAFANA_BEARER_TOKEN=

JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0 -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError
JAVA_OPTS=
